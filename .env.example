# Compose project
COMPOSE_PROJECT_NAME=readme

# Image publishing
DOCKER_IMAGE_NAMESPACE=your-dockerhub-id
IMAGE_TAG=latest

# Ports
FRONTEND_PORT=80
BACKEND_PORT=8202
POSTGRES_PORT=5420

# Database
POSTGRES_DB=readme
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Security
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend/base URLs
# If you change FRONTEND_PORT, update the 3 URL values below to match it.
APP_BASE_URL=http://localhost
FRONT_OAUTH_REDIRECT_URI=http://localhost/oauth/callback
CORS_ALLOWED_ORIGINS=http://localhost

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost/api/oauth/kakao/callback

# Files
FILE_UPLOAD_DIR=/app/uploads

# External APIs
KAKAO_BOOK_API_BASE_URL=https://dapi.kakao.com/v3/search/book
KAKAO_BOOK_REST_API_KEY=

# Payment
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
KAKAO_SECRET_KEY=
NAVER_PAY_CLIENT_ID=
NAVER_PAY_CLIENT_SECRET=
NAVER_PAY_CHAIN_ID=
NAVER_PAY_MERCHANT_ID=

# Seed / init
SEED_MEMBERS_ENABLED=false
SEED_COMMERCE_ENABLED=false
SEED_API_PRODUCT_COUNT=1000
SQL_INIT_MODE=never
